  "resultProfiles": [
    {"id": "optimal", "name": "压力舒适区", "description": "您目前处于良好的压力平衡状态，能够有效应对日常生活中的压力源，并保持身心健康。", "conditions": [{"dimension": "stressLoad", "operator": "lt", "value": 2.5}, {"dimension": "emotionalStrain", "operator": "lt", "value": 2.5}, {"dimension": "recoveryCapacity", "operator": "gt", "value": 3.5}], "tags": ["平衡", "健康"], "summary": "您的压力管理水平良好。", "recommendations": ["继续保持当前的生活方式", "规律运动和充足睡眠", "培养积极的兴趣爱好"], "careLevel": "无需特别干预"},
    {"id": "balanced", "name": "压力平衡型", "description": "您目前处于相对平衡的压力状态，有一定的压力但可以应对。需要注意生活中的压力管理。", "conditions": [{"dimension": "stressLoad", "operator": "between", "value": [2.5, 3.5]}, {"dimension": "emotionalStrain", "operator": "lt", "value": 3.5}, {"dimension": "recoveryCapacity", "operator": "between", "value": [2.5, 3.5]}], "tags": ["平衡", "可调节"], "summary": "您的压力水平处于中等可承受范围。", "recommendations": ["注意工作与生活平衡", "培养压力管理技巧", "保持社交活动"], "careLevel": "自我调节"},
    {"id": "elevated", "name": "压力升高型", "description": "您承受的压力超过舒适区，需要关注并采取措施来管理压力。", "conditions": [{"dimension": "stressLoad", "operator": "gt", "value": 3.5}, {"dimension": "emotionalStrain", "operator": "between", "value": [2.5, 3.5]}], "tags": ["压力升高", "需关注"], "summary": "您的压力水平偏高，建议适当调整。", "recommendations": ["分析压力来源并制定应对计划", "学习放松技巧如深呼吸、冥想", "必要时寻求专业支持"], "careLevel": "需要关注"},
    {"id": "high", "name": "高压状态", "description": "您目前承受较高压力，需要积极关注心理健康并采取有效的压力管理策略。", "conditions": [{"dimension": "stressLoad", "operator": "gt", "value": 3.5}, {"dimension": "emotionalStrain", "operator": "gt", "value": 3.5}], "tags": ["高压", "需干预"], "summary": "您的压力水平较高，建议及时采取行动。", "recommendations": ["立即开始压力管理计划", "考虑咨询心理健康专业人士", "评估生活重大变化的可能性"], "careLevel": "建议干预"},
