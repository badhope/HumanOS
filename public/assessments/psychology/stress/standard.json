  "questions": [
    {"id": "stress-std-1", "text": "在过去的两周里，您感到压力大的频率是？", "type": "single-choice", "dimension": "stressLoad", "options": [{"id": "A", "text": "从未", "value": 1}, {"id": "B", "text": "偶尔（几天）", "value": 2}, {"id": "C", "text": "经常（一半以上天数）", "value": 3}, {"id": "D", "text": "几乎每天", "value": 4}]},
    {"id": "stress-std-2", "text": "您对目前工作/生活压力的感受是？", "type": "single-choice", "dimension": "stressLoad", "options": [{"id": "A", "text": "轻松可控", "value": 1}, {"id": "B", "text": "有些压力但能应对", "value": 2}, {"id": "C", "text": "压力较大，勉强应付", "value": 3}, {"id": "D", "text": "压力难以承受", "value": 4}]},
    {"id": "stress-std-3", "text": "您觉得自己的责任和负担有多重？", "type": "single-choice", "dimension": "stressLoad", "options": [{"id": "A", "text": "没什么负担", "value": 1}, {"id": "B", "text": "有一些但能承受", "value": 2}, {"id": "C", "text": "负担较重", "value": 3}, {"id": "D", "text": "不堪重负", "value": 4}]},
    {"id": "stress-std-4", "text": "在过去的两周里，您感到焦虑不安的频率是？", "type": "single-choice", "dimension": "emotionalStrain", "options": [{"id": "A", "text": "从未", "value": 1}, {"id": "B", "text": "偶尔", "value": 2}, {"id": "C", "text": "经常", "value": 3}, {"id": "D", "text": "总是", "value": 4}]},
    {"id": "stress-std-5", "text": "您容易因为小事而烦躁或生气吗？", "type": "single-choice", "dimension": "emotionalStrain", "options": [{"id": "A", "text": "从不", "value": 1}, {"id": "B", "text": "偶尔", "value": 2}, {"id": "C", "text": "经常", "value": 3}, {"id": "D", "text": "总是", "value": 4}]},
    {"id": "stress-std-6", "text": "在过去的两周里，您感到情绪低落的频率是？", "type": "single-choice", "dimension": "emotionalStrain", "options": [{"id": "A", "text": "从未", "value": 1}, {"id": "B", "text": "偶尔", "value": 2}, {"id": "C", "text": "经常", "value": 3}, {"id": "D", "text": "几乎每天", "value": 4}]},
    {"id": "stress-std-7", "text": "您会无缘无故地感到紧张或害怕吗？", "type": "single-choice", "dimension": "emotionalStrain", "options": [{"id": "A", "text": "从未", "value": 1}, {"id": "B", "text": "偶尔", "value": 2}, {"id": "C", "text": "经常", "value": 3}, {"id": "D", "text": "总是", "value": 4}]},
    {"id": "stress-std-8", "text": "当您感到压力时，您通常能恢复吗？", "type": "single-choice", "dimension": "recoveryCapacity", "options": [{"id": "A", "text": "很快就能恢复", "value": 1}, {"id": "B", "text": "需要一些时间", "value": 2}, {"id": "C", "text": "需要很长时间", "value": 3}, {"id": "D", "text": "很难恢复", "value": 4}]},
    {"id": "stress-std-9", "text": "您的睡眠质量如何？", "type": "single-choice", "dimension": "recoveryCapacity", "options": [{"id": "A", "text": "很好，能充分休息", "value": 1}, {"id": "B", "text": "还行，偶尔失眠或早醒", "value": 2}, {"id": "C", "text": "不太好，经常失眠或早醒", "value": 3}, {"id": "D", "text": "很差，严重失眠", "value": 4}]},
    {"id": "stress-std-10", "text": "您有规律的放松活动吗（如运动、冥想、阅读等）？", "type": "single-choice", "dimension": "recoveryCapacity", "options": [{"id": "A", "text": "有，且坚持得很好", "value": 1}, {"id": "B", "text": "有，但不太规律", "value": 2}, {"id": "C", "text": "偶尔", "value": 3}, {"id": "D", "text": "几乎没有", "value": 4}]},
    {"id": "stress-std-11", "text": "您有可以倾诉心事的人吗？", "type": "single-choice", "dimension": "recoveryCapacity", "options": [{"id": "A", "text": "有，且经常交流", "value": 1}, {"id": "B", "text": "有，但不经常交流", "value": 2}, {"id": "C", "text": "偶尔有人可以倾诉", "value": 3}, {"id": "D", "text": "几乎没有", "value": 4}]},
    {"id": "stress-std-12", "text": "您有头痛、肌肉紧张或胃部不适等身体症状吗？", "type": "single-choice", "dimension": "physicalSymptoms", "options": [{"id": "A", "text": "从未", "value": 1}, {"id": "B", "text": "偶尔", "value": 2}, {"id": "C", "text": "经常", "value": 3}, {"id": "D", "text": "非常频繁", "value": 4}]},
    {"id": "stress-std-13", "text": "您感到心悸或呼吸困难吗（排除身体疾病原因）？", "type": "single-choice", "dimension": "physicalSymptoms", "options": [{"id": "A", "text": "从未", "value": 1}, {"id": "B", "text": "偶尔", "value": 2}, {"id": "C", "text": "经常", "value": 3}, {"id": "D", "text": "总是", "value": 4}]},
    {"id": "stress-std-14", "text": "您对目前生活的整体满意度是？", "type": "single-choice", "dimension": "stressLoad", "options": [{"id": "A", "text": "非常满意", "value": 1}, {"id": "B", "text": "比较满意", "value": 2}, {"id": "C", "text": "不太满意", "value": 3}, {"id": "D", "text": "很不满意", "value": 4}]},
    {"id": "stress-std-15", "text": "您觉得压力对您的身体健康有影响吗？", "type": "single-choice", "dimension": "physicalSymptoms", "options": [{"id": "A", "text": "没有影响", "value": 1}, {"id": "B", "text": "有一些影响", "value": 2}, {"id": "C", "text": "有较大影响", "value": 3}, {"id": "D", "text": "严重影响", "value": 4}]},
    {"id": "stress-std-16", "text": "您对自己应对压力的能力有信心吗？", "type": "single-choice", "dimension": "recoveryCapacity", "options": [{"id": "A", "text": "非常有信心", "value": 1}, {"id": "B", "text": "有些信心", "value": 2}, {"id": "C", "text": "信心不足", "value": 3}, {"id": "D", "text": "完全没有信心", "value": 4}]},
    {"id": "stress-std-17", "text": "您会通过吃东西、喝酒、吸烟或上网来应对压力吗？", "type": "single-choice", "dimension": "recoveryCapacity", "options": [{"id": "A", "text": "从未", "value": 1}, {"id": "B", "text": "偶尔", "value": 2}, {"id": "C", "text": "经常", "value": 3}, {"id": "D", "text": "总是这样", "value": 4}]},
    {"id": "stress-std-18", "text": "您对未来的担忧和焦虑程度如何？", "type": "single-choice", "dimension": "emotionalStrain", "options": [{"id": "A", "text": "很少担忧", "value": 1}, {"id": "B", "text": "有些担忧但能控制", "value": 2}, {"id": "C", "text": "经常担忧", "value": 3}, {"id": "D", "text": "总是过度担忧", "value": 4}]},
    {"id": "stress-std-19", "text": "您的工作/学习效率与平时相比有变化吗？", "type": "single-choice", "dimension": "stressLoad", "options": [{"id": "A", "text": "和平时一样", "value": 1}, {"id": "B", "text": "略有下降", "value": 2}, {"id": "C", "text": "明显下降", "value": 3}, {"id": "D", "text": "完全无法正常工作/学习", "value": 4}]},
    {"id": "stress-std-20", "text": "总体来说，您觉得自己目前的身心状态是？", "type": "single-choice", "dimension": "physicalSymptoms", "options": [{"id": "A", "text": "非常好", "value": 1}, {"id": "B", "text": "还不错", "value": 2}, {"id": "C", "text": "有些不适", "value": 3}, {"id": "D", "text": "很不好", "value": 4}]}
  ]
