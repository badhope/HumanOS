# =============================================================================
#  心镜 MindMirror - 环境配置模板
#  复制此文件为 .env 或 .env.development 并修改配置
# =============================================================================

# 应用标题
VITE_APP_TITLE=心镜 MindMirror

# API 基础地址
VITE_API_BASE_URL=http://localhost:8000

# 是否使用后端计算引擎
VITE_USE_BACKEND_CALCULATION=false

# 是否启用用户系统
VITE_ENABLE_USER_SYSTEM=false

# 是否启用云端保存
VITE_CLOUD_SAVE_ENABLED=false

# 是否启用调试模式
VITE_DEBUG_MODE=true
