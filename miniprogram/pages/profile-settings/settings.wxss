.section {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 26rpx;
  color: #94A3B8;
  padding: 24rpx 36rpx 12rpx;
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx;
  border-bottom: 1rpx solid #F0F2F5;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 30rpx;
  color: #1E293B;
}

.form-input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #64748B;
}

.form-value {
  font-size: 28rpx;
  color: #64748B;
}
