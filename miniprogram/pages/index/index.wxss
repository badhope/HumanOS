.welcome-card {
  padding: 48rpx 24rpx;
  background: linear-gradient(135deg, #2E7CF5 0%, #5A9CF7 100%);
  color: white;
  border-radius: 0 0 48rpx 48rpx;
  margin: 0 -24rpx;
}

.greeting {
  font-size: 28rpx;
  opacity: 0.9;
}

.nickname {
  font-size: 48rpx;
  font-weight: 700;
  margin-top: 12rpx;
}

.subtext {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 8rpx;
}

.quick-actions {
  display: flex;
  gap: 24rpx;
  padding: 36rpx 0;
}

.action-item {
  flex: 1;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 36rpx 0;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 28rpx;
  color: #1E293B;
}

.section {
  margin-bottom: 36rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
}

.section-more {
  font-size: 24rpx;
  color: #64748B;
}

.stats-grid {
  display: flex;
  gap: 24rpx;
}

.stat-item {
  flex: 1;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 36rpx 0;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #2E7CF5;
}

.stat-label {
  font-size: 24rpx;
  color: #64748B;
  margin-top: 8rpx;
}

.assessment-list,
.record-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.assessment-card,
.record-card {
  display: flex;
  gap: 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 36rpx;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.assessment-icon,
.record-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  flex-shrink: 0;
}

.assessment-info,
.record-info {
  flex: 1;
}

.assessment-name,
.record-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
}

.assessment-desc {
  font-size: 24rpx;
  color: #64748B;
  margin-top: 8rpx;
}

.assessment-meta,
.record-time {
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 12rpx;
}

.record-score {
  font-size: 24rpx;
  color: #64748B;
  margin-top: 4rpx;
}

.record-score-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #2E7CF5;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.record-card {
  display: flex;
  gap: 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 36rpx;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.record-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  flex-shrink: 0;
}

.record-info {
  flex: 1;
}

.record-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
}

.record-result {
  font-size: 24rpx;
  color: #64748B;
  margin-top: 8rpx;
}

.record-time {
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 12rpx;
}

.empty-state {
  text-align: center;
  padding: 96rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
}

.empty-hint {
  font-size: 24rpx;
  color: #64748B;
  margin-top: 12rpx;
}

.empty-btn {
  margin-top: 48rpx;
}
