.webview-container {
  width: 100%;
  height: 100vh;
  position: relative;
}

.loading-container {
  width: 100%;
  height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: #16213e;
}

.loading-text {
  color: #8a8a8a;
  font-size: 28rpx;
}

.error-container {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  background-color: rgba(22, 33, 62, 0.95);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  box-sizing: border-box;
  z-index: 100;
}

.error-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.error-title {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.error-desc {
  color: #8a8a8a;
  font-size: 28rpx;
  text-align: center;
  margin-bottom: 60rpx;
  line-height: 1.5;
}

.retry-btn {
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #e94560 0%, #c73e54 100%);
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}
