<view class="webview-container">
  <view wx:if="{{!webUrl}}" class="loading-container">
    <view class="loading-text">正在加载...</view>
  </view>
  <web-view 
    wx:else 
    src="{{webUrl}}" 
    bindload="onWebViewLoad" 
    binderror="onWebViewError"
  ></web-view>
  <view wx:if="{{errorMessage}}" class="error-container">
    <view class="error-icon">⚠️</view>
    <view class="error-title">页面加载失败</view>
    <view class="error-desc">{{errorMessage}}</view>
    <button class="retry-btn" bindtap="retryLoad">重新加载</button>
  </view>
</view>