{
  "appId": "com.guanxinjie.mindmirror",
  "productName": "心镜 MindMirror",
  "directories": {
    "output": "electron-release",
    "buildResources": "build"
  },
  "files": [
    "dist/**/*",
    "electron/**/*"
  ],
  "compression": "store",
  "win": {
    "target": [
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "icon": "public/pwa-512x512.png",
    "artifactName": "心镜-MindMirror-${version}-${arch}-便携版.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "心镜 MindMirror",
    "installerIcon": "public/pwa-512x512.png",
    "uninstallerIcon": "public/pwa-512x512.png",
    "deleteAppDataOnUninstall": false
  },
  "portable": {
    "artifactName": "心镜-MindMirror-${version}-${arch}-便携版.${ext}"
  },
  "mac": {
    "target": ["dmg", "zip"],
    "icon": "build/icon.icns",
    "category": "public.app-category.healthcare",
    "artifactName": "心镜-MindMirror-${version}-${arch}.${ext}"
  },
  "dmg": {
    "contents": [
      {
        "x": 130,
        "y": 220
      },
      {
        "x": 410,
        "y": 220,
        "type": "link",
        "path": "/Applications"
      }
    ]
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "icon": "build/icon.png",
    "category": "HealthCare",
    "artifactName": "心镜-MindMirror-${version}-${arch}.${ext}"
  }
}
